# Groq API — guiones, títulos, descripciones (GRATIS)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — DALL-E 3 thumbnails (~$0.04 por imagen)
OPENAI_API_KEY=sk-your-key-here

# ElevenLabs — voz Juan Fit (JaviMar)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-javimart-voice-id

# HeyGen — avatar video con lip-sync
HEYGEN_API_KEY=your-heygen-api-key
HEYGEN_AVATAR_ID=your-juanfit-avatar-id
HEYGEN_VOICE_ID=your-heygen-voice-id

# Pexels — B-Roll videos gratuitos
PEXELS_API_KEY=your-pexels-api-key

# YouTube OAuth2
YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# n8n
N8N_WEBHOOK_URL=http://localhost:5678

# Canal
CHANNEL_NAME=JOTATIGER.FIT
AVATAR_IMAGE_PATH=./assets/juan-fit-base.jpg
