# Groq API — guiones, títulos, descripciones (GRATIS)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI — DALL-E 3 thumbnails (~$0.04 por imagen)
OPENAI_API_KEY=sk-your-key-here

# Google Colab — XTTS v2 voz + LatentSync lip-sync
# Exponer con ngrok desde Colab: ngrok http 5000
COLAB_WEBHOOK_URL=https://your-ngrok-url.ngrok.io
COLAB_TTS_ENDPOINT=/tts
COLAB_LIPSYNC_ENDPOINT=/lipsync

# YouTube OAuth2
YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# n8n
N8N_WEBHOOK_URL=http://localhost:5678

# Canal
CHANNEL_NAME=JOTATIGER.FIT
AVATAR_IMAGE_PATH=./assets/juan-fit-avatar.jpg
